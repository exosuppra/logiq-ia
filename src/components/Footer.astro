---
const year = new Date().getFullYear();
---

<footer
  class="border-t"
  style="border-color: #e5e5e5; background: #fafafa;"
>
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <div>
        <a
          href="/"
          class="inline-flex items-center gap-2 font-display text-sm font-semibold"
          style="color: #0a0a0a;"
        >
          <img
            src="/logo-mark.png"
            alt="LOGIQ IA"
            width="28"
            height="28"
            class="h-7 w-7 object-contain"
          />
          <span><span class="font-extrabold">LOGIQ</span> <span style="color: #6d28d9;">IA</span></span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed" style="color: #404040;">
          Cabinet d'ingénierie IA et automatisation pour entreprises et acteurs
          touristiques. Basé à Gréoux-les-Bains, Alpes-de-Haute-Provence.
        </p>

        <div class="mt-6">
          <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
            Retrouvez-nous
          </h3>
          <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-2 text-sm" style="color: #404040;">
            <li>
              <a href="https://www.malt.fr/profile/quentinduroy" target="_blank" rel="noopener" class="hover:underline">
                Malt
              </a>
            </li>
            <li>
              <a href="https://www.codeur.com/-logiq-ia" target="_blank" rel="noopener" class="hover:underline">
                Codeur
              </a>
            </li>
            {/* À ajouter plus tard si besoin : Upwork, LinkedIn */}
          </ul>
        </div>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
          Services
        </h3>
        <ul class="mt-4 space-y-2 text-sm" style="color: #404040;">
          <li><a href="/services" class="hover:underline">Vue d'ensemble</a></li>
          <li><a href="/realisations" class="hover:underline">Réalisations</a></li>
          <li><a href="/a-propos" class="hover:underline">À propos</a></li>
          <li><a href="/contact" class="hover:underline">Devis</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
          Nos produits
        </h3>
        <ul class="mt-4 space-y-2 text-sm" style="color: #404040;">
          <li>
            <a href="https://manga-ai.fr" target="_blank" rel="noopener" class="hover:underline">
              Manga AI
            </a>
          </li>
          <li>
            <a href="/produits#apidia" class="hover:underline">Apidia</a>
          </li>
          <li>
            <a href="/produits#oto" class="hover:underline">OTO</a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
          Légal
        </h3>
        <ul class="mt-4 space-y-2 text-sm" style="color: #404040;">
          <li><a href="/mentions-legales" class="hover:underline">Mentions légales</a></li>
          <li><a href="/contact" class="hover:underline">Nous contacter</a></li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-3 border-t pt-6 text-xs sm:flex-row sm:items-center"
      style="border-color: #e5e5e5; color: #737373;"
    >
      <div>
        © {year} LOGIQ IA · Gréoux-les-Bains, Provence · Fondé par{" "}
        <a
          href="https://quentin-duroy.fr"
          target="_blank"
          rel="noopener"
          class="underline decoration-dotted underline-offset-2 transition-colors hover:text-neutral-700"
          style="color: #737373;"
        >
          Quentin Duroy
        </a>
      </div>
      <div>SIRET 904 758 737 00038</div>
    </div>
  </div>
</footer>
