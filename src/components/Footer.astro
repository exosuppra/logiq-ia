---
const year = new Date().getFullYear();
---

<footer
  class="border-t"
  style="border-color: #e5e5e5; background: #fafafa;"
>
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-10 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
      <div>
        <a
          href="/"
          class="inline-flex items-center gap-2 font-display text-sm font-semibold"
          style="color: #0a0a0a;"
        >
          <span
            class="relative inline-flex h-7 w-7 items-center justify-center rounded-md text-[10px] font-bold text-white"
            style="background: linear-gradient(135deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%); box-shadow: 0 6px 18px -6px rgba(124,58,237,0.45);"
          >
            LIA
          </span>
          <span><span class="font-extrabold">LOGIQ</span> <span style="color: #6d28d9;">IA</span></span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed" style="color: #404040;">
          Cabinet d'ingénierie IA et automatisation pour entreprises et acteurs
          touristiques. Basé à Gréoux-les-Bains, Alpes-de-Haute-Provence.
        </p>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
          Services
        </h3>
        <ul class="mt-4 space-y-2 text-sm" style="color: #404040;">
          <li><a href="/services" class="hover:underline">Vue d'ensemble</a></li>
          <li><a href="/produits" class="hover:underline">Produits IA</a></li>
          <li><a href="/contact" class="hover:underline">Devis</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
          Écosystème
        </h3>
        <ul class="mt-4 space-y-2 text-sm" style="color: #404040;">
          <li>
            <a href="https://manga-ai.fr" target="_blank" rel="noopener" class="hover:underline">
              Manga AI
            </a>
          </li>
          <li>
            <a href="https://quentin-duroy.fr" target="_blank" rel="noopener" class="hover:underline">
              Quentin DUROY
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-semibold uppercase tracking-[0.15em]" style="color: #0a0a0a;">
          Légal
        </h3>
        <ul class="mt-4 space-y-2 text-sm" style="color: #404040;">
          <li><a href="/mentions-legales" class="hover:underline">Mentions légales</a></li>
          <li>
            <a
              href="https://www.linkedin.com/in/quentin-duroy"
              target="_blank"
              rel="noopener"
              class="hover:underline"
            >
              LinkedIn fondateur
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-3 border-t pt-6 text-xs sm:flex-row sm:items-center"
      style="border-color: #e5e5e5; color: #737373;"
    >
      <div>© {year} LOGIQ IA · Quentin DUROY · Gréoux-les-Bains, Provence</div>
      <div>SIRET en cours d'immatriculation</div>
    </div>
  </div>
</footer>
