---
// Interactive neural-network background. Drop inside any position:relative,
// overflow-hidden container. Fills the parent and reacts to the pointer.
interface Props { class?: string }
const { class: cls = "" } = Astro.props;
---
<canvas class:list={["neural-bg", cls]} data-neural aria-hidden></canvas>

<style>
  .neural-bg { position: absolute; inset: 0; width: 100%; height: 100%; display: block; z-index: 0; pointer-events: none; }
</style>

<script>
  function initNeural(cv: HTMLCanvasElement) {
    const ctx = cv.getContext("2d");
    if (!ctx) return;
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    let W = 0, H = 0;
    const mouse = { x: -9999, y: -9999 };
    type P = { x: number; y: number; vx: number; vy: number };
    let pts: P[] = [];
    const LINE = "124,58,237";   // violet
    const HOT = "220,38,38";     // red near pointer

    function size() {
      const r = cv.getBoundingClientRect();
      W = cv.width = Math.max(1, Math.floor(r.width * dpr));
      H = cv.height = Math.max(1, Math.floor(r.height * dpr));
      const n = Math.min(110, Math.max(28, Math.floor((r.width * r.height) / 13000)));
      pts = Array.from({ length: n }, () => ({
        x: Math.random() * W, y: Math.random() * H,
        vx: (Math.random() - 0.5) * 0.22 * dpr, vy: (Math.random() - 0.5) * 0.22 * dpr,
      }));
    }

    const D = 130;
    function frame() {
      const dd = D * dpr;
      ctx.clearRect(0, 0, W, H);
      for (const p of pts) {
        p.x += p.vx; p.y += p.vy;
        if (p.x < 0 || p.x > W) p.vx *= -1;
        if (p.y < 0 || p.y > H) p.vy *= -1;
      }
      for (let i = 0; i < pts.length; i++) {
        for (let j = i + 1; j < pts.length; j++) {
          const dx = pts[i].x - pts[j].x, dy = pts[i].y - pts[j].y;
          const d = Math.hypot(dx, dy);
          if (d < dd) {
            ctx.strokeStyle = `rgba(${LINE},${(1 - d / dd) * 0.4})`;
            ctx.lineWidth = 1 * dpr;
            ctx.beginPath(); ctx.moveTo(pts[i].x, pts[i].y); ctx.lineTo(pts[j].x, pts[j].y); ctx.stroke();
          }
        }
      }
      const mx = mouse.x * dpr, my = mouse.y * dpr, R = 170 * dpr;
      for (const p of pts) {
        const dm = Math.hypot(p.x - mx, p.y - my);
        const near = dm < R;
        if (near) {
          const a = (1 - dm / R) * 0.85;
          ctx.strokeStyle = `rgba(${HOT},${a})`; ctx.lineWidth = 1.3 * dpr;
          ctx.beginPath(); ctx.moveTo(p.x, p.y); ctx.lineTo(mx, my); ctx.stroke();
        }
        ctx.fillStyle = near ? `rgb(${HOT})` : `rgba(${LINE},0.85)`;
        ctx.beginPath(); ctx.arc(p.x, p.y, (near ? 3 : 2) * dpr, 0, 7); ctx.fill();
      }
      raf = requestAnimationFrame(frame);
    }

    let raf = 0;
    window.addEventListener("pointermove", (e) => {
      const r = cv.getBoundingClientRect();
      mouse.x = e.clientX - r.left; mouse.y = e.clientY - r.top;
    });
    window.addEventListener("pointerleave", () => { mouse.x = -9999; mouse.y = -9999; });
    const ro = new ResizeObserver(() => size());
    ro.observe(cv);
    size();
    if (!matchMedia("(prefers-reduced-motion: reduce)").matches) raf = requestAnimationFrame(frame);
    else frame();
  }

  document.querySelectorAll<HTMLCanvasElement>("canvas[data-neural]").forEach(initNeural);
</script>
