          >
            Prendre rendez-vous
            <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden>
              <path d="M6 3l5 5-5 5V3z" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>
