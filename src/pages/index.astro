          class="mt-10 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors hover:underline"
          style="color: #6d28d9;"
        >
          Découvrir le cabinet et son fondateur
          <svg viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3" aria-hidden>
            <path d="M6 3l5 5-5 5V3z" />
          </svg>
        </a>
      </div>
    </section>

    {/* FAQ */}
    <section class="relative py-24 sm:py-32">
      <div class="mx-auto max-w-3xl px-6">
        <div class="mb-12 text-center">
          <div
            class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
            style="border-color: rgba(124,58,237,0.30); background: rgba(124,58,237,0.06); color: #6d28d9;"
          >
            Questions fréquentes
          </div>
          <h2 class="mt-6 text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
            Vous vous demandez<br />sûrement…
          </h2>
        </div>

        <div class="space-y-3">
          {faqs.map((f) => (
            <details class="group rounded-2xl border bg-white px-6 py-4" style="border-color: #e5e5e5;">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-semibold" style="color: #0a0a0a;">
