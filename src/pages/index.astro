---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const products = [
  {
    title: "Manga AI",
    tagline: "Notre app phare grand public",
    description:
      "Créez un manga complet jusqu'à 240 pages à partir d'un simple synopsis. Trilingue, accessible à tous, sans savoir dessiner. Le générateur de manga par IA le plus avancé du marché.",
    href: "/produits/manga-ai/",
    external: "https://manga-ai.fr",
    cta: "Découvrir Manga AI",
    accent: "rose",
    featured: true,
  },
  {
    title: "Apidia",
    tagline: "Plateforme IA touristique",
    description:
      "Conseiller en séjour virtuel et qualification automatique de la donnée touristique. Connecté en direct à plus de 6 000 fiches établissements actualisées chaque jour.",
    href: "/produits#apidia",
    cta: "Voir Apidia",
    accent: "violet",
  },
  {
    title: "OTO",
    tagline: "Agents IA métier",
    description:
      "Agents IA sur mesure qui automatisent une soixantaine de tâches métier au quotidien. Conçus pour les pôles communication, marketing et administration.",
    href: "/produits#oto",
    cta: "Voir OTO",
    accent: "fuchsia",
  },
];

const benefits = [
  {
    icon: "📈",
    title: "Du temps libéré, immédiatement",
    body: "Nos agents IA automatisent jusqu'à 80 % des tâches répétitives. Vos équipes se concentrent sur ce qui crée vraiment de la valeur.",
  },
  {
    icon: "💰",
    title: "Des coûts maîtrisés",
    body: "Pas d'usine à gaz, pas de licences à six chiffres. Des solutions calibrées pour livrer un ROI dès le premier trimestre.",
  },
  {
    icon: "⚡",
    title: "Déploiement rapide",
    body: "Premier livrable opérationnel sous 2 à 4 semaines. Itérations rapides selon vos retours terrain.",
  },
  {
    icon: "🛡️",
    title: "Conformité et souveraineté",
    body: "RGPD, EU AI Act, hébergement européen. Pour les cas sensibles, nous opérons sur infrastructure souveraine 100 % locale.",
  },
];

const accent: Record<string, string> = {
  violet: "#7c3aed",
  rose: "#dc2626",
  fuchsia: "#c026d3",
};
---

<Layout>
  <Header />

  <main class="bg-white">
    {/* HERO */}
    <section class="relative overflow-hidden">
      <div
        aria-hidden
        class="pointer-events-none absolute inset-0 opacity-[0.04]"
        style="background-image: linear-gradient(to right, #000 1px, transparent 1px), linear-gradient(to bottom, #000 1px, transparent 1px); background-size: 80px 80px;"
      >
      </div>

      <div
        aria-hidden
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-96 opacity-30"
        style="background: radial-gradient(ellipse at 30% 50%, #a78bfa 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, #f87171 0%, transparent 60%); filter: blur(80px);"
      >
      </div>

      <div class="mx-auto max-w-6xl px-6 pb-24 pt-32 sm:pt-40">
        <div
          class="hero-fade hero-fade-1 inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
          style="border-color: rgba(220,38,38,0.30); background: rgba(220,38,38,0.05); color: #b91c1c;"
        >
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #ef4444;"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: #dc2626;"></span>
          </span>
          Cabinet d'ingénierie IA
        </div>

        <h1
          class="hero-fade hero-fade-2 mt-6 text-balance text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl lg:text-8xl"
          style="color: #0a0a0a;"
        >
          L'IA qui<br />
          <span class="text-gradient">transforme</span><br />
          votre entreprise.
        </h1>

        <p
          class="hero-fade hero-fade-3 mt-8 max-w-2xl text-xl leading-relaxed"
          style="color: #404040;"
        >
          <strong style="color: #0a0a0a;">LOGIQ IA</strong> conçoit, déploie et opère des
          produits IA qui livrent. Des solutions pensées pour le terrain, prêtes
          à tourner dès la première semaine.
        </p>

        <div class="hero-fade hero-fade-3 mt-10 flex flex-col items-start gap-4 sm:flex-row">
          <a
            href="/produits"
            class="group relative inline-flex items-center gap-2 overflow-hidden rounded-full px-8 py-3.5 text-base font-semibold text-white transition-all hover:-translate-y-0.5"
            style="background: linear-gradient(90deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%); box-shadow: 0 12px 30px -10px rgba(124,58,237,0.45);"
          >
            Découvrir nos produits
            <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden>
              <path d="M6 3l5 5-5 5V3z" />
            </svg>
          </a>
          <a
            href="/contact"
            class="inline-flex items-center gap-2 rounded-full border px-8 py-3.5 text-base font-semibold transition-all hover:-translate-y-0.5"
            style="border-color: #d4d4d4; color: #0a0a0a;"
          >
            Discuter d'un projet
          </a>
        </div>
      </div>
    </section>

    {/* PRODUITS — section star, focus promotion */}
    <section id="produits" class="relative py-24 sm:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-16 max-w-2xl">
          <div
            class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
            style="border-color: rgba(220,38,38,0.30); background: rgba(220,38,38,0.05); color: #b91c1c;"
          >
            Nos produits
          </div>
          <h2 class="mt-6 text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
            Des produits IA<br />
            <span class="text-gradient">qui livrent</span>.
          </h2>
          <p class="mt-4 text-lg" style="color: #404040;">
            Trois solutions phares, du SaaS grand public à l'IA métier, toutes en
            production et utilisées au quotidien par des milliers de clients.
          </p>
        </div>

        {/* MANGA AI : carte large featured */}
        <article
          class="mb-6 overflow-hidden rounded-3xl border transition-all hover:-translate-y-1"
          style="border-color: rgba(220,38,38,0.30); background: linear-gradient(135deg, rgba(220,38,38,0.04) 0%, rgba(255,255,255,1) 100%); box-shadow: 0 14px 35px -15px rgba(220,38,38,0.20);"
        >
          <div class="grid gap-8 p-8 md:grid-cols-[1.2fr_1fr] md:gap-12 md:p-12">
            <div>
              <div
                class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-wider"
                style="border-color: rgba(220,38,38,0.35); background: rgba(220,38,38,0.08); color: #b91c1c;"
              >
                ★ Produit phare grand public
              </div>
              <h3 class="mt-4 text-4xl font-bold tracking-tight md:text-5xl" style="color: #0a0a0a;">
                Manga AI
              </h3>
              <p class="mt-2 text-lg" style="color: #404040;">
                Le générateur de manga par IA.
              </p>
              <p class="mt-4 text-base leading-relaxed" style="color: #404040;">
                Créez un manga complet jusqu'à 240 pages à partir d'un simple
                synopsis. Trilingue FR/EN/ES, accessible sans savoir dessiner. La
                solution la plus avancée du marché pour produire des mangas
                longs avec une cohérence visuelle et narrative bluffante.
              </p>
              <p class="mt-3 text-base leading-relaxed" style="color: #404040;">
                Déjà adopté par des créateurs, des éditeurs, des enseignants et
                des agences créatives partout dans le monde. À découvrir sur{" "}
                <a
                  href="https://manga-ai.fr"
                  target="_blank"
                  rel="noopener"
                  class="font-semibold underline decoration-from-font underline-offset-4"
                  style="color: #dc2626;"
                >
                  manga-ai.fr
                </a>.
              </p>

              <div class="mt-6 flex flex-col gap-3 sm:flex-row">
                <a
                  href="/produits/manga-ai/"
                  class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-base font-semibold text-white transition-all hover:-translate-y-0.5"
                  style="background: linear-gradient(90deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%); box-shadow: 0 12px 30px -10px rgba(220,38,38,0.40);"
                >
                  Lire la fiche produit
                </a>
                <a
                  href="https://manga-ai.fr"
                  target="_blank"
                  rel="noopener"
                  class="inline-flex items-center gap-2 rounded-full border px-6 py-3 text-base font-semibold transition-all hover:-translate-y-0.5"
                  style="border-color: #d4d4d4; color: #0a0a0a;"
                >
                  Essayer gratuitement
                  <svg viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5" aria-hidden>
                    <path d="M5.5 3a.5.5 0 010-1h7a.5.5 0 01.5.5v7a.5.5 0 01-1 0V3.707l-8.146 8.147a.5.5 0 01-.708-.708L11.293 3H5.5z" />
                  </svg>
                </a>
              </div>
            </div>
            <div
              class="hidden aspect-[4/3] items-center justify-center overflow-hidden rounded-2xl border text-6xl font-bold tracking-tighter text-gradient md:flex md:text-7xl"
              style="border-color: #e5e5e5; background: linear-gradient(135deg, #fafafa 0%, #ffffff 100%);"
            >
              MANGA AI
            </div>
          </div>
        </article>

        {/* APIDIA + OTO : grille de 2 */}
        <div class="grid gap-5 md:grid-cols-2">
          {products.filter((p) => !p.featured).map((p) => (
            <a
              href={p.href}
              class="group flex flex-col rounded-2xl border bg-white p-6 transition-all hover:-translate-y-1"
              style="border-color: #e5e5e5;"
              onmouseover={`this.style.borderColor='${accent[p.accent]}40'; this.style.boxShadow='0 14px 35px -15px ${accent[p.accent]}30'`}
              onmouseout="this.style.borderColor='#e5e5e5'; this.style.boxShadow='none'"
            >
              <div class="text-xs uppercase tracking-wider" style={`color: ${accent[p.accent]};`}>
                {p.tagline}
              </div>
              <h3 class="mt-2 text-2xl font-bold tracking-tight" style="color: #0a0a0a;">{p.title}</h3>
              <p class="mt-3 flex-1 leading-relaxed" style="color: #404040;">{p.description}</p>
              <div class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold" style="color: #6d28d9;">
                {p.cta}
                <svg viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3 transition-transform group-hover:translate-x-0.5" aria-hidden>
                  <path d="M6 3l5 5-5 5V3z" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* BENEFICES — pourquoi nous choisir */}
    <section class="relative bg-neutral-50 py-24 sm:py-32">
      <div class="mx-auto max-w-6xl px-6">
        <div class="mb-16 max-w-2xl">
          <div
            class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
            style="border-color: rgba(124,58,237,0.30); background: rgba(124,58,237,0.06); color: #6d28d9;"
          >
            Pourquoi LOGIQ IA
          </div>
          <h2 class="mt-6 text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
            Quatre raisons de<br />
            <span class="text-gradient">nous faire confiance</span>.
          </h2>
        </div>

        <div class="grid gap-5 md:grid-cols-2">
          {benefits.map((b) => (
            <article
              class="flex gap-5 rounded-2xl border bg-white p-6"
              style="border-color: #e5e5e5;"
            >
              <div class="text-4xl">{b.icon}</div>
              <div>
                <h3 class="text-lg font-bold tracking-tight" style="color: #0a0a0a;">{b.title}</h3>
                <p class="mt-2 text-base leading-relaxed" style="color: #404040;">{b.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* TRUST SIGNALS — preuve sociale sans nommer Quentin */}
    <section class="relative py-24 sm:py-32">
      <div class="mx-auto max-w-5xl px-6 text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="color: #0a0a0a;">
          Une expertise reconnue.
        </h2>
        <p class="mx-auto mt-4 max-w-2xl text-lg" style="color: #404040;">
          Lauréats internationaux, statuts officiels, références publiques.
          Notre travail est reconnu par les acteurs majeurs du secteur.
        </p>

        <div class="mt-12 grid grid-cols-2 gap-6 sm:grid-cols-4">
          <div class="rounded-2xl border bg-white p-6" style="border-color: #e5e5e5;">
            <div class="text-3xl">🏆</div>
            <div class="mt-3 text-sm font-bold" style="color: #0a0a0a;">Lauréat Make Grid</div>
            <div class="mt-1 text-xs" style="color: #737373;">Concours international 2025</div>
          </div>
          <div class="rounded-2xl border bg-white p-6" style="border-color: #e5e5e5;">
            <div class="text-3xl">🇫🇷</div>
            <div class="mt-3 text-sm font-bold" style="color: #0a0a0a;">National Treasure</div>
            <div class="mt-1 text-xs" style="color: #737373;">Top 1 % France Lovable</div>
          </div>
          <div class="rounded-2xl border bg-white p-6" style="border-color: #e5e5e5;">
            <div class="text-3xl">🎙️</div>
            <div class="mt-3 text-sm font-bold" style="color: #0a0a0a;">Record YouTube FROT</div>
            <div class="mt-1 text-xs" style="color: #737373;">Webinaire 4,8/5 satisfaction</div>
          </div>
          <div class="rounded-2xl border bg-white p-6" style="border-color: #e5e5e5;">
            <div class="text-3xl">🎓</div>
            <div class="mt-3 text-sm font-bold" style="color: #0a0a0a;">23 certifications IA</div>
            <div class="mt-1 text-xs" style="color: #737373;">Anthropic · Make · Lovable</div>
          </div>
        </div>
      </div>
    </section>

    {/* CTA final */}
    <section class="relative overflow-hidden bg-neutral-50 py-24 sm:py-32">
      <div
        aria-hidden
        class="pointer-events-none absolute inset-x-0 top-1/4 -z-10 h-72 opacity-25"
        style="background: radial-gradient(ellipse at 30% 50%, #a78bfa 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, #f87171 0%, transparent 60%); filter: blur(80px);"
      >
      </div>

      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
          Votre projet IA<br />commence ici.
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg" style="color: #404040;">
          Audit offert en 30 minutes. À l'issue, vous repartez avec un
          diagnostic clair, un plan d'action concret et un devis transparent.
        </p>
        <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/contact"
            class="group relative inline-flex items-center gap-2 overflow-hidden rounded-full px-8 py-3.5 text-base font-semibold text-white transition-all hover:-translate-y-0.5"
            style="background: linear-gradient(90deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%); box-shadow: 0 12px 30px -10px rgba(220,38,38,0.45);"
          >
            Prendre rendez-vous
            <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden>
              <path d="M6 3l5 5-5 5V3z" />
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
