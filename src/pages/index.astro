<style>
  /* ---- Marquee clients (100% CSS, transform GPU) ---- */
  .marquee {
    position: relative;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
    mask-image: linear-gradient(90deg, transparent, #000 12%, #000 88%, transparent);
  }
  .marquee-track {
    display: flex;
    width: max-content;
    gap: 3rem;
    animation: marquee 32s linear infinite;
  }
  .marquee:hover .marquee-track { animation-play-state: paused; }
  .marquee-item {
    font-size: 0.95rem;
    font-weight: 600;
    color: #525252;
    white-space: nowrap;
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ---- Bento : halo au survol ---- */
  .bento-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.35s ease;
    pointer-events: none;
    background: radial-gradient(420px circle at 50% 0%, color-mix(in srgb, var(--accent) 14%, transparent), transparent 70%);
  }
  .bento-card:hover .bento-glow { opacity: 1; }
  .bento-card { transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease; }
  .bento-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, #e5e5e5) !important;
    box-shadow: 0 16px 38px -18px color-mix(in srgb, var(--accent) 55%, transparent);
  }

  /* ---- Méthode : cartes empilées au scroll ---- */
  .steps-stack { display: flex; flex-direction: column; gap: 1.25rem; }
  .step-card { position: sticky; }
  @media (prefers-reduced-motion: reduce) {
    .step-card { position: static; }
    .marquee-track { animation: none; }
  }
</style>

<script>
  // Compteurs animés — démarrent quand la section entre dans le viewport
  const counters = document.querySelectorAll<HTMLElement>(".count");
  if (counters.length) {
    const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const fmt = (v: number, dec: number) =>
      dec ? v.toFixed(dec).replace(".", ",") : Math.round(v).toString();

    const run = (el: HTMLElement) => {
      const to = parseFloat(el.dataset.to || "0");
      const dec = parseInt(el.dataset.dec || "0", 10);
      if (reduce) { el.textContent = fmt(to, dec); return; }
      const dur = 1400;
      const t0 = performance.now();
      const tick = (t: number) => {
        const p = Math.min((t - t0) / dur, 1);
        // easeOutCubic
        el.textContent = fmt(to * (1 - Math.pow(1 - p, 3)), dec);
        if (p < 1) requestAnimationFrame(tick);
      };
      requestAnimationFrame(tick);
    };

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            run(e.target as HTMLElement);
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.6 },
    );
    counters.forEach((c) => io.observe(c));
  }
</script>
