---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="Mentions légales · LOGIQ IA"
  description="Mentions légales du site logiq-ia.fr."
  canonical="https://logiq-ia.fr/mentions-legales/"
>
  <Header />

  <main class="bg-white">
    <section class="mx-auto max-w-3xl px-6 py-32 sm:py-40">
      <a href="/" class="mb-8 inline-flex items-center gap-2 text-sm font-medium" style="color: #6d28d9;">
        <svg viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3" aria-hidden>
          <path d="M11 13l-5-5 5-5v10z" />
        </svg>
        Retour à l'accueil
      </a>

      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
        Mentions légales
      </h1>

      <div class="mt-12 space-y-8 text-base leading-relaxed" style="color: #404040;">
        <section>
          <h2 class="text-xl font-bold" style="color: #0a0a0a;">Éditeur</h2>
          <p class="mt-2">
            <strong>LOGIQ IA</strong> — enseigne de Quentin Duroy, entrepreneur individuel.<br />
            83560 Saint-Julien, France.<br />
            Email :
            <a href="mailto:contact@logiq-ia.fr" style="color: #6d28d9;">
              contact@logiq-ia.fr
            </a>
          </p>
          <p class="mt-2 text-sm" style="color: #737373;">
            SIREN 904 758 737 · SIRET (siège) 904 758 737 00038 · Code APE 85.59B.<br />
            Directeur de la publication : Quentin Duroy.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold" style="color: #0a0a0a;">Hébergement</h2>
          <p class="mt-2">
            Cloudflare, Inc. · 101 Townsend St, San Francisco, CA 94107, USA.<br />
            Le site est servi en edge via Cloudflare Pages.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold" style="color: #0a0a0a;">Propriété intellectuelle</h2>
          <p class="mt-2">
            L'ensemble des contenus présents sur ce site (textes, images, code,
            design, produits, marques) sont la propriété exclusive de LOGIQ IA,
            sauf mention contraire. Toute reproduction, distribution ou
            utilisation sans autorisation préalable est interdite.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold" style="color: #0a0a0a;">Données personnelles</h2>
          <p class="mt-2">
            Ce site ne collecte aucune donnée personnelle de tracking, n'utilise
            aucun cookie de tracking et n'embarque aucun outil d'analytics. Si
            vous nous contactez par email, vos coordonnées sont uniquement
            utilisées pour répondre à votre demande et ne sont pas conservées
            au-delà.
          </p>
        </section>

        <section>
          <h2 class="text-xl font-bold" style="color: #0a0a0a;">Liens externes</h2>
          <p class="mt-2">
            Ce site contient des liens vers des sites tiers, notamment notre
            produit phare{" "}
            <a
              href="https://manga-ai.fr"
              target="_blank"
              rel="noopener"
              style="color: #dc2626;"
            >
              manga-ai.fr
            </a>. Nous ne sommes pas responsables du contenu des sites externes.
          </p>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
