---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
---

<Layout
  title="Produits LOGIQ IA · Manga AI, Apidia, OTO"
  description="Nos produits IA en production : Manga AI (générateur de manga), Apidia (conseiller en séjour virtuel), OTO (premier agent IA en OT français)."
  canonical="https://logiq-ia.fr/produits/"
>
  <Header />

  <main class="bg-white">
    <section class="relative overflow-hidden pt-32 sm:pt-40">
      <div
        aria-hidden
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-96 opacity-25"
        style="background: radial-gradient(ellipse at 30% 50%, #a78bfa 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, #f87171 0%, transparent 60%); filter: blur(80px);"
      >
      </div>

      <div class="mx-auto max-w-5xl px-6 pb-16">
        <div
          class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
          style="border-color: rgba(220,38,38,0.30); background: rgba(220,38,38,0.05); color: #b91c1c;"
        >
          Produits
        </div>
        <h1 class="mt-6 text-balance text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl" style="color: #0a0a0a;">
          Du <span class="text-gradient">SaaS grand public</span><br />
          au sur-mesure métier.
        </h1>
        <p class="mt-6 max-w-2xl text-lg" style="color: #404040;">
          Nos produits sont nés sur le terrain, en production chez nos clients
          ou commercialisés au grand public.
        </p>
      </div>
    </section>

    {/* MANGA AI featured */}
    <section class="mx-auto max-w-5xl px-6 py-16">
      <article
        class="rounded-3xl border p-8 transition-all md:p-12"
        style="border-color: rgba(220,38,38,0.30); background: linear-gradient(135deg, rgba(220,38,38,0.04) 0%, rgba(255,255,255,1) 100%); box-shadow: 0 14px 35px -15px rgba(220,38,38,0.20);"
      >
        <div class="grid gap-8 md:grid-cols-[1.2fr_1fr] md:gap-12">
          <div>
            <div
              class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-[11px] font-semibold uppercase tracking-wider"
              style="border-color: rgba(220,38,38,0.35); background: rgba(220,38,38,0.08); color: #b91c1c;"
            >
              ★ Produit phare grand public
            </div>
            <h2 class="mt-4 text-4xl font-bold tracking-tight md:text-5xl" style="color: #0a0a0a;">
              Manga AI
            </h2>
            <p class="mt-2 text-lg" style="color: #404040;">
              Générateur de manga par intelligence artificielle.
            </p>
            <p class="mt-4 text-base leading-relaxed" style="color: #404040;">
              <a
                href="https://manga-ai.fr"
                target="_blank"
                rel="noopener"
                class="font-semibold underline decoration-from-font underline-offset-4"
                style="color: #dc2626;"
              >
                Manga AI
              </a>{" "}
              transforme un synopsis en manga complet jusqu'à 240 pages, planches
              et bulles incluses. Trilingue FR/EN/ES. En production sur{" "}
              <strong style="color: #0a0a0a;">manga-ai.fr</strong> et hébergé sur
              Cloudflare.
            </p>

            <div class="mt-6 flex flex-col gap-3 sm:flex-row">
              <a
                href="/produits/manga-ai/"
                class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-base font-semibold text-white transition-all hover:-translate-y-0.5"
                style="background: linear-gradient(90deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%); box-shadow: 0 12px 30px -10px rgba(220,38,38,0.40);"
              >
                Lire la fiche produit
              </a>
              <a
                href="https://manga-ai.fr"
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 rounded-full border px-6 py-3 text-base font-semibold transition-all hover:-translate-y-0.5"
                style="border-color: #d4d4d4; color: #0a0a0a;"
              >
                Visiter manga-ai.fr
                <svg viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5" aria-hidden>
                  <path d="M5.5 3a.5.5 0 010-1h7a.5.5 0 01.5.5v7a.5.5 0 01-1 0V3.707l-8.146 8.147a.5.5 0 01-.708-.708L11.293 3H5.5z" />
                </svg>
              </a>
            </div>
          </div>
          <div
            class="aspect-[4/3] overflow-hidden rounded-2xl border"
            style="border-color: #e5e5e5; background: linear-gradient(135deg, #fafafa 0%, #ffffff 100%);"
          >
            <div
              class="flex h-full w-full items-center justify-center text-6xl font-bold tracking-tighter text-gradient md:text-7xl"
            >
              MANGA AI
            </div>
          </div>
        </div>
      </article>
    </section>

    {/* Apidia + OTO */}
    <section class="mx-auto max-w-5xl px-6 py-16">
      <div class="grid gap-5 md:grid-cols-2">
        <article id="apidia" class="rounded-2xl border bg-white p-6" style="border-color: #e5e5e5;">
          <div class="text-xs uppercase tracking-wider" style="color: #6d28d9;">
            Plateforme IA · Tourisme
          </div>
          <h3 class="mt-2 text-2xl font-bold tracking-tight" style="color: #0a0a0a;">
            Apidia
          </h3>
          <p class="mt-3 leading-relaxed" style="color: #404040;">
            Plateforme et agent IA chargé de la qualification des données
            touristiques au sein de l'Office de Tourisme du Pays de Manosque.
            Connecté en direct à 6 000+ fiches scrapées par jour. Conseiller en
            séjour virtuel pour le public, outil métier pour les agents
            d'accueil, l'administratif, le suivi RH et la planification
            éditoriale.
          </p>
          <a
            href="https://apidia.lovable.app/catalogue"
            target="_blank"
            rel="noopener"
            class="mt-5 inline-flex items-center gap-1.5 text-sm font-semibold transition-colors hover:underline"
            style="color: #6d28d9;"
          >
            Voir le catalogue de services Apidia
            <svg viewBox="0 0 16 16" fill="currentColor" class="h-3 w-3" aria-hidden>
              <path d="M5.5 3a.5.5 0 010-1h7a.5.5 0 01.5.5v7a.5.5 0 01-1 0V3.707l-8.146 8.147a.5.5 0 01-.708-.708L11.293 3H5.5z" />
            </svg>
          </a>
        </article>

        <article id="oto" class="rounded-2xl border bg-white p-6" style="border-color: #e5e5e5;">
          <div class="text-xs uppercase tracking-wider" style="color: #dc2626;">
            Agents IA · Premier en OT français
          </div>
          <h3 class="mt-2 text-2xl font-bold tracking-tight" style="color: #0a0a0a;">
            OTO & OTO_Mail
          </h3>
          <p class="mt-3 leading-relaxed" style="color: #404040;">
            Premier agent IA sur mesure déployé dans un office de tourisme
            français (mars 2025). OTO assiste la communication digitale, marketing
            et la gestion des ordres de mission. Couplé à OTO_Mail (assistant
            email), ils couvrent une soixantaine de tâches métier au quotidien.
          </p>
        </article>
      </div>
    </section>

    <Footer />
  </main>
</Layout>
