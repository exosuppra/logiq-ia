<script>
  const buttons = Array.from(
    document.querySelectorAll<HTMLButtonElement>(".filter-btn"),
  );
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(".project-card"),
  );
  const emptyState = document.getElementById("empty-state");

  function setActive(btn: HTMLButtonElement) {
    buttons.forEach((b) => {
      const active = b === btn;
      b.dataset.active = active ? "true" : "false";
      b.style.borderColor = active ? "#0a0a0a" : "#e5e5e5";
      b.style.background = active ? "#0a0a0a" : "#ffffff";
      b.style.color = active ? "#ffffff" : "#404040";
    });
  }

  buttons.forEach((btn) => {
    btn.addEventListener("click", () => {
      const filter = btn.dataset.filter;
      setActive(btn);
      let visible = 0;
      cards.forEach((card) => {
        const show = filter === "Tous" || card.dataset.category === filter;
        card.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (emptyState) emptyState.classList.toggle("hidden", visible !== 0);
    });
  });
</script>
