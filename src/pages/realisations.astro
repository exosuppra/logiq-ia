---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

type Project = {
  name: string;
  monogram: string;
  category: string;
  concept: string;
  client?: string;
  description: string;
  tags: string[];
  href: string;
  internal?: boolean;
  ownDomain?: boolean;
  featured?: boolean;
  private?: boolean;
  status?: string;
  accent: string;
};

const categories = [
  "Tous",
  "Agent IA",
  "Produit IA",
  "Application & SaaS",
  "Tourisme & Territoire",
  "Hôtellerie & Restauration",
  "Commerce & Boutique",
  "Loisir & Expérience",
  "Jeu vidéo",
  "Services locaux",
];

const projects: Project[] = [
  {
    name: "Manga AI",
    monogram: "MA",
    category: "Produit IA",
    concept: "Générateur de manga par IA",
    description:
      "Notre produit phare grand public. Transforme un simple synopsis en manga complet jusqu'à 240 pages, trilingue, sans savoir dessiner. Édition case par case.",
    tags: ["SaaS grand public", "IA générative", "Trilingue"],
    href: "https://manga-ai.fr",
    ownDomain: true,
    featured: true,
    accent: "#dc2626",
  },
  {
    name: "Agent SDR autonome",
    monogram: "SDR",
    category: "Agent IA",
    concept: "Agent commercial IA 100 % autonome",
    description:
      "Un agent commercial entièrement autonome : on lui confie un profil de client idéal, et il identifie, qualifie et engage des prospects sur LinkedIn, décroche un rendez-vous et journalise tout dans un CRM — en décidant seul de l'ordre de ses actions. Le cerveau (Claude) planifie, les outils exécutent. Mémoire persistante, supervision proactive, conformité Do-Not-Contact.",
    tags: ["Python", "Agent autonome", "Claude · Tool use"],
    href: "",
    private: true,
    accent: "#7c3aed",
  },
  {
    name: "Apidia",
    monogram: "AP",
    category: "Agent IA",
    concept: "Conseiller en séjour virtuel autonome",
    client: "Office de Tourisme & des Congrès du Pays de Manosque",
    description:
      "Un agent qui consulte l'intégralité des fiches établissements et recommande, comme le ferait un conseiller en séjour humain, les meilleurs renseignements touristiques selon la demande du visiteur. Surtout, il entretient sa propre base : il va chercher les informations manquantes sur internet, puis contacte les propriétaires de chaque fiche établissement ou événement pour leur faire confirmer ce qu'il a relevé. Connecté à 6 000+ fiches.",
    tags: ["Agent autonome", "Auto-qualification", "6 000+ fiches"],
    href: "/produits#apidia",
    internal: true,
    accent: "#6d28d9",
  },
  {
    name: "OTO",
    monogram: "OTO",
    category: "Agent IA",
    concept: "Agent IA chargé de projet web",
    client: "Office de Tourisme & des Congrès du Pays de Manosque",
    description:
      "Un agent IA qui pilote lui-même des solutions d'automatisation et prend en charge une grande partie des missions d'un chargé de projet web au quotidien : communication digitale, marketing, production de contenu et coordination. Construit sur une orchestration Make qu'il déclenche et enchaîne de façon autonome.",
    tags: ["Agent autonome", "Make", "Automatisation métier"],
    href: "/produits#oto",
    internal: true,
    accent: "#c026d3",
  },
  {
    name: "OTO_Mail",
    monogram: "MAIL",
    category: "Agent IA",
    concept: "Agent IA e-mail, agenda & GRC",
    client: "Office de Tourisme & des Congrès du Pays de Manosque",
    description:
      "Le binôme d'OTO, sur le même principe d'autonomie, appliqué à la relation : traitement et rédaction des e-mails, alimentation de la base de données agenda et gestion de la relation client (GRC). Il trie, répond, enregistre et tient les bases à jour sans supervision permanente.",
    tags: ["Agent autonome", "E-mail & GRC", "Base agenda"],
    href: "/produits#oto",
    internal: true,
    accent: "#7c3aed",
  },
  {
    name: "LoveLink",
    monogram: "LL",
    category: "Produit IA",
    concept: "Compagnons IA conversationnels",
    description:
      "Une plateforme sociale de personnages IA : chat naturel, appels vocaux ultra-réalistes, génération d'images et mémoire des interactions passées.",
    tags: ["Produit IA", "Voix & image", "Temps réel"],
    href: "https://lovelink-ai.lovable.app",
    accent: "#c026d3",
  },
  {
    name: "Le Jardin de Célina",
    monogram: "JC",
    category: "Hôtellerie & Restauration",
    concept: "Maison d'hôtes & restaurant premium",
    description:
      "Site vitrine haut de gamme d'un lieu d'hébergement et de gastronomie à Valensole : chambres, chalets, table signature et événementiel. En ligne sur son propre domaine.",
    tags: ["Hôtellerie", "Restaurant", "Événementiel"],
    href: "https://lejardindecelina.com",
    ownDomain: true,
    accent: "#b91c1c",
  },
  {
    name: "L'Oustaù de Greù",
    monogram: "OG",
    category: "Commerce & Boutique",
    concept: "Épicerie & cave à vins de Provence",
    description:
      "Boutique en ligne d'une épicerie fine et cave à vins de Gréoux-les-Bains : produits régionaux, spiritueux et coffrets apéritif, avec comptes clients et livraison Chronopost à domicile ou en point relais.",
    tags: ["E-commerce", "Produits régionaux", "Livraison"],
    href: "https://loustaudegreu.fr",
    ownDomain: true,
    accent: "#7c3aed",
  },
  {
    name: "Esparron-de-Verdon",
    monogram: "EV",
    category: "Tourisme & Territoire",
    concept: "Guide touristique officiel",
    description:
      "Le site vitrine complet d'une destination du Parc naturel régional du Verdon : activités, agenda, hébergements, restaurants, éco-gestes et patrimoine réunis en un guide clair.",
    tags: ["Tourisme institutionnel", "Multi-rubriques", "SEO destination"],
    href: "https://esparron-de-verdon.lovable.app",
    accent: "#7c3aed",
  },
  {
    name: "Verdon Mystères",
    monogram: "VM",
    category: "Loisir & Expérience",
    concept: "Jeu d'énigmes grandeur nature + mini-jeu en ligne",
    description:
      "Une expérience outdoor sur le lac d'Esparron, prolongée par un mini-jeu vidéo jouable en ligne : conçu sous forme de formulaire interactif, il fait vivre les énigmes directement depuis le navigateur. Le site présente le jeu, les règles, les partenaires loueurs, l'offre groupes B2B et un carrousel d'avis clients.",
    tags: ["Mini-jeu en ligne", "Formulaire interactif", "Offre B2B"],
    href: "https://verdon-mysteres.lovable.app",
    accent: "#c026d3",
  },
  {
    name: "La Pièce Qui Attend",
    monogram: "LPQA",
    category: "Jeu vidéo",
    concept: "Jeu d'horreur psychologique 3D",
    description:
      "Notre projet le plus ambitieux côté création : un jeu d'horreur narratif à la première personne (~30-45 min), construit avec Three.js et WebGL, packagé en .exe Windows hors-ligne via Electron. Audio spatialisé HRTF, miroirs reflétés en temps réel, assets PBR libres (CC0). Des énigmes scénarisées — radio, dessins, frigo — s'enchaînent jusqu'à une révélation finale en plein jour. Une V2 est prévue sur Unreal Engine 5, avec une sortie commerciale envisagée sur Steam.",
    tags: ["Three.js · WebGL", "Electron", "Audio spatialisé HRTF"],
    href: "",
    status: "En développement · sortie Steam envisagée",
    accent: "#b91c1c",
  },
  {
    name: "RENOVXPERTS",
    monogram: "RX",
    category: "Services locaux",
    concept: "Artisan rénovation multi-métiers",
    description:
      "Site de génération de leads pour un artisan local : catalogue de 12 corps de métier, arguments de réassurance et formulaire de devis avec consentement RGPD.",
    tags: ["SEO local", "Devis en ligne", "Lead generation"],
    href: "https://renovxperts-geo-engine.lovable.app",
    accent: "#dc2626",
  },
  {
    name: "Meal&Move",
    monogram: "MM",
    category: "Application & SaaS",
    concept: "Tracker nutrition & fitness",
    description:
      "Une application web avec espace membre : suivi des repas et de l'activité, coaching personnalisé et statistiques de progression au fil du temps.",
    tags: ["Web app", "Espace membre", "Dashboard"],
    href: "https://mealandmove.lovable.app",
    accent: "#6d28d9",
  },
  {
    name: "Intense Verdon",
    monogram: "IV",
    category: "Application & SaaS",
    concept: "Plateforme de comité éditorial",
    description:
      "Un outil métier collaboratif avec authentification : gestion, planification et validation de la ligne éditoriale d'un média local, à plusieurs mains.",
    tags: ["Outil métier", "Authentification", "Collaboratif"],
    href: "https://intense-verdon-edito.lovable.app",
    accent: "#7c3aed",
  },
];
---

<Layout
  title="Réalisations LOGIQ IA · Sites, applications et produits IA"
  description="Découvrez les réalisations LOGIQ IA : sites vitrines, applications web, plateformes métier et produits IA. Du guide touristique au SaaS, en passant par l'artisan local et l'hôtellerie premium."
  canonical="https://logiq-ia.fr/realisations/"
>
  <Header />

  <main class="bg-white">
    {/* HERO */}
    <section class="relative overflow-hidden pt-32 sm:pt-40">
      <div
        aria-hidden
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-96 opacity-25"
        style="background: radial-gradient(ellipse at 30% 50%, #a78bfa 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, #f87171 0%, transparent 60%); filter: blur(80px);"
      >
      </div>

      <div class="mx-auto max-w-5xl px-6 pb-10">
        <div
          class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
          style="border-color: rgba(124,58,237,0.30); background: rgba(124,58,237,0.05); color: #6d28d9;"
        >
          Réalisations
        </div>
        <h1 class="mt-6 text-balance text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl" style="color: #0a0a0a;">
          Ce que nous<br />
          <span class="text-gradient">construisons</span>.
        </h1>
        <div class="mt-6 grid items-center gap-8 sm:grid-cols-[1fr_auto]">
          <p class="max-w-2xl text-lg" style="color: #404040;">
            Du site vitrine au produit IA, en passant par l'application métier :
            une sélection de projets qui montrent l'étendue de ce que nous savons
            concevoir, déployer et opérer.
          </p>
          <img
            src="/mascotte/conseil.webp"
            alt=""
            width="240"
            height="240"
            decoding="async"
            class="mx-auto hidden w-44 select-none sm:block lg:w-56"
          />
        </div>

        {/* Stats */}
        <div class="mt-10 flex flex-wrap gap-x-10 gap-y-4">
          <div>
            <div class="text-3xl font-bold tracking-tight" style="color: #0a0a0a;">14</div>
            <div class="text-sm" style="color: #737373;">projets réalisés</div>
          </div>
          <div>
            <div class="text-3xl font-bold tracking-tight" style="color: #0a0a0a;">9</div>
            <div class="text-sm" style="color: #737373;">secteurs couverts</div>
          </div>
          <div>
            <div class="text-3xl font-bold tracking-tight text-gradient">∞</div>
            <div class="text-sm" style="color: #737373;">du statique au SaaS</div>
          </div>
        </div>
      </div>
    </section>

    {/* ILS NOUS FONT CONFIANCE */}
    <section class="mx-auto max-w-5xl px-6 pt-4">
      <div
        class="rounded-2xl border p-6 sm:p-8"
        style="border-color: #e5e5e5; background: linear-gradient(135deg, rgba(124,58,237,0.04) 0%, rgba(255,255,255,1) 60%);"
      >
        <div class="text-xs font-semibold uppercase tracking-[0.2em]" style="color: #6d28d9;">
          Ils nous font confiance
        </div>
        <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-3">
          {[
            "Office de Tourisme & des Congrès du Pays de Manosque",
            "Le Jardin de Célina",
            "L'Oustaù de Greù",
            "RENOVXPERTS",
          ].map((c) => (
            <span
              class="rounded-full border px-4 py-2 text-sm font-semibold"
              style="border-color: #e5e5e5; background: #ffffff; color: #0a0a0a;"
            >
              {c}
            </span>
          ))}
        </div>
        <p class="mt-4 text-sm" style="color: #737373;">
          Offices de tourisme, commerces, artisans et éditeurs : nous livrons
          aussi bien des sites vitrines que des agents IA en production.
        </p>
      </div>
    </section>

    {/* FILTERS */}
    <section class="mx-auto max-w-5xl px-6 pt-8">
      <div class="flex flex-wrap gap-2" id="filter-bar">
        {categories.map((cat, i) => (
          <button
            type="button"
            class="filter-btn rounded-full border px-4 py-1.5 text-sm font-medium transition-all"
            data-filter={cat}
            data-active={i === 0 ? "true" : "false"}
            style={
              i === 0
                ? "border-color: #0a0a0a; background: #0a0a0a; color: #ffffff;"
                : "border-color: #e5e5e5; background: #ffffff; color: #404040;"
            }
          >
            {cat}
          </button>
        ))}
      </div>
    </section>

    {/* GRID */}
    <section class="mx-auto max-w-5xl px-6 py-12">
      <div class="grid gap-6 sm:grid-cols-2" id="project-grid">
        {projects.map((p) => (
          <article
            class="project-card group flex flex-col overflow-hidden rounded-2xl border bg-white transition-all hover:-translate-y-1"
            data-category={p.category}
            style={`border-color: ${p.featured ? "rgba(220,38,38,0.30)" : "#e5e5e5"}; box-shadow: 0 10px 30px -18px ${p.accent}55;`}
          >
            {/* Visual tile */}
            <div
              class="relative flex aspect-[16/9] items-center justify-center overflow-hidden border-b"
              style={`border-color: #efefef; background: linear-gradient(135deg, ${p.accent}0d 0%, #ffffff 70%);`}
            >
              <span
                aria-hidden
                class="pointer-events-none absolute -right-6 -top-8 h-32 w-32 rounded-full opacity-40"
                style={`background: radial-gradient(circle, ${p.accent}40 0%, transparent 70%); filter: blur(24px);`}
              ></span>
              <span
                class="text-5xl font-black tracking-tighter"
                style={`background: linear-gradient(135deg, ${p.accent} 0%, #0a0a0a 130%); -webkit-background-clip: text; background-clip: text; color: transparent;`}
              >
                {p.monogram}
              </span>
              {p.featured && (
                <span
                  class="absolute left-3 top-3 rounded-full px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider text-white"
                  style="background: linear-gradient(90deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%);"
                >
                  ★ Produit phare
                </span>
              )}
              {p.ownDomain && !p.featured && (
                <span
                  class="absolute left-3 top-3 rounded-full border px-2.5 py-1 text-[10px] font-semibold uppercase tracking-wider"
                  style="border-color: #d4d4d4; background: rgba(255,255,255,0.9); color: #404040;"
                >
                  Domaine propre
                </span>
              )}
            </div>

            {/* Body */}
            <div class="flex flex-1 flex-col p-6">
              <div
                class="inline-flex w-fit items-center gap-1.5 rounded-full px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wide"
                style={`background: ${p.accent}12; color: ${p.accent};`}
              >
                {p.category}
              </div>
              <h2 class="mt-3 text-xl font-bold tracking-tight" style="color: #0a0a0a;">
                {p.name}
              </h2>
              <p class="mt-1 text-sm font-medium" style={`color: ${p.accent};`}>
                {p.concept}
              </p>
              {p.client && (
                <div
                  class="mt-3 inline-flex w-fit items-start gap-1.5 rounded-lg border px-2.5 py-1.5 text-[11px] font-semibold leading-snug"
                  style={`border-color: ${p.accent}33; background: ${p.accent}0a; color: #404040;`}
                >
                  <svg viewBox="0 0 16 16" fill="currentColor" class="mt-px h-3 w-3 shrink-0" style={`color: ${p.accent};`} aria-hidden>
                    <path d="M2 15V5.5A1.5 1.5 0 013.5 4H6V2.5A1.5 1.5 0 017.5 1h5A1.5 1.5 0 0114 2.5V15h-4v-3H6v3H2zm2-2h2v-2H4v2zm0-3h2V8H4v2zm4 3h2v-2H8v2zm0-3h2V8H8v2zm0-3h2V5H8v2z" />
                  </svg>
                  <span>Client&nbsp;: {p.client}</span>
                </div>
              )}
              <p class="mt-3 text-sm leading-relaxed" style="color: #404040;">
                {p.description}
              </p>

              <div class="mt-4 flex flex-wrap gap-1.5">
                {p.tags.map((t) => (
                  <span
                    class="rounded-md border px-2 py-0.5 text-[11px] font-medium"
                    style="border-color: #e5e5e5; background: #fafafa; color: #525252;"
                  >
                    {t}
                  </span>
                ))}
              </div>

              {!p.href ? (
                <span
                  class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full border px-5 py-3 text-sm font-semibold"
                  style={`border-color: ${p.accent}40; background: ${p.accent}0d; color: ${p.accent};`}
                >
                  {p.private && (
                    <svg viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5 shrink-0" aria-hidden>
                      <path d="M4 7V5a4 4 0 118 0v2h.5A1.5 1.5 0 0114 8.5v5A1.5 1.5 0 0112.5 15h-9A1.5 1.5 0 012 13.5v-5A1.5 1.5 0 013.5 7H4zm2 0h4V5a2 2 0 10-4 0v2z" />
                    </svg>
                  )}
                  {p.status ?? "Projet privé · sur devis"}
                </span>
              ) : (
                <a
                  href={p.href}
                  target={p.internal ? undefined : "_blank"}
                  rel={p.internal ? undefined : "noopener"}
                  class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-semibold text-white transition-all hover:-translate-y-0.5"
                  style={`background: ${p.accent}; box-shadow: 0 12px 26px -12px ${p.accent};`}
                >
                  {p.internal ? "Voir la fiche produit" : "Visiter le site"}
                  <svg viewBox="0 0 16 16" fill="currentColor" class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" aria-hidden>
                    <path d="M5.5 3a.5.5 0 010-1h7a.5.5 0 01.5.5v7a.5.5 0 01-1 0V3.707l-8.146 8.147a.5.5 0 01-.708-.708L11.293 3H5.5z" />
                  </svg>
                </a>
              )}
            </div>
          </article>
        ))}
      </div>

      <p id="empty-state" class="hidden py-16 text-center text-sm" style="color: #737373;">
        Aucun projet dans cette catégorie pour le moment.
      </p>
    </section>

    {/* ÉTUDES DE CAS */}
    <section class="relative bg-neutral-50 py-24 sm:py-32">
      <div class="mx-auto max-w-5xl px-6">
        <div
          class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
          style="border-color: rgba(220,38,38,0.30); background: rgba(220,38,38,0.05); color: #b91c1c;"
        >
          Études de cas
        </div>
        <h2 class="mt-6 text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
          Des résultats <span class="text-gradient">mesurables</span>.
        </h2>
        <p class="mt-6 max-w-2xl text-lg" style="color: #404040;">
          Trois projets, trois contextes, une même exigence : des chiffres
          concrets plutôt que des promesses.
        </p>

        <div class="mt-12 space-y-6">
          {/* Étude de cas 1 — Apidia */}
          <article class="rounded-2xl border bg-white p-8" style="border-color: #e5e5e5;">
            <h3 class="text-2xl font-bold tracking-tight" style="color: #0a0a0a;">
              Apidia
            </h3>
            <p class="mt-1 text-sm font-medium" style="color: #7c3aed;">
              Plateforme IA de données touristiques
            </p>

            <div class="mt-6 grid gap-6 sm:grid-cols-3">
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider" style="color: #737373;">
                  Contexte
                </div>
                <p class="mt-2 text-sm leading-relaxed" style="color: #404040;">
                  L'Office de Tourisme et des Congrès du Pays de Manosque gère
                  une base de plus de 6 000 fiches établissements à maintenir
                  à jour.
                </p>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider" style="color: #737373;">
                  Défi
                </div>
                <p class="mt-2 text-sm leading-relaxed" style="color: #404040;">
                  La qualification manuelle de la donnée touristique est
                  chronophage et les informations deviennent vite obsolètes.
                </p>
              </div>
              <div>
                <div class="text-xs font-semibold uppercase tracking-wider" style="color: #737373;">
                  Solution
                </div>
                <p class="mt-2 text-sm leading-relaxed" style="color: #404040;">
                  Une plateforme IA d'auto-qualification qui va chercher
                  l'information sur le web et met à jour les bases
                  automatiquement, doublée d'un conseiller en séjour virtuel
                  pour le public et d'outils métier (planification éditoriale,
                  KPI, RH).
                </p>
              </div>
            </div>

            <div class="mt-8 grid gap-6 border-t pt-4 sm:grid-cols-3" style="border-color: #e5e5e5;">
              <div>
                <div class="text-2xl font-bold tracking-tight" style="color: #7c3aed;">6 000+</div>
                <div class="mt-1 text-xs" style="color: #737373;">fiches actualisées chaque jour</div>
              </div>
              <div>
                <div class="text-2xl font-bold tracking-tight" style="color: #7c3aed;">24 h</div>
                <div class="mt-1 text-xs" style="color: #737373;">cycle complet de mise à jour</div>
              </div>
              <div>
                <div class="text-2xl font-bold tracking-tight" style="color: #7c3aed;">50 k€</div>
                <div class="mt-1 text-xs" style="color: #737373;">valeur marché estimée</div>
              </div>
            </div>
          </article>

          {/* Étude de cas 2 — OTO & OTO_Mail */}
          <article class="rounded-2xl border bg-white p-8" style="border-color: #e5e5e5;">
            <h3 class="text-2xl font-bold tracking-tight" style="color: #0a0a0a;">
              OTO &amp; OTO_Mail
            </h3>
            <p class="mt-1 text-sm font-medium" style="color: #c026d3;">
              Agents IA métier
            </p>

            <div class="mt-6 grid gap-6 sm:grid-cols-3">
