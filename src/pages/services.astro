---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const services = [
  {
    id: "agents",
    icon: "🤖",
    title: "Agents IA sur mesure",
    accent: "violet",
    lead: "Des assistants IA dédiés à votre métier, qui travaillent pour vous 24/7.",
    benefits: [
      "Vos équipes libérées des tâches répétitives à faible valeur ajoutée",
      "Réponses instantanées aux questions de vos clients ou collaborateurs",
      "Intégration native avec vos outils existants (Office 365, Google Workspace, CRM, ERP)",
      "Évolutif : on commence petit, on grandit avec vos besoins",
      "Retour sur investissement dès le premier mois",
    ],
  },
  {
    id: "automation",
    icon: "⚙️",
    title: "Automatisation des workflows",
    accent: "red",
    lead: "On débranche vos équipes du copier-coller et de la double saisie.",
    benefits: [
      "Jusqu'à 80 % des tâches manuelles automatisées",
      "Données synchronisées en temps réel entre vos outils",
      "Reporting automatique : finis les tableurs à jour à la main",
      "Gain de temps massif dès la première semaine",
      "Plans de continuité et alertes en cas d'incident",
    ],
  },
  {
    id: "conseil",
    icon: "🧠",
    title: "Conseil stratégique IA",
    accent: "fuchsia",
    lead: "Un cadre clair pour faire de l'IA un levier de croissance, pas un gadget.",
    benefits: [
      "Audit de vos opportunités IA en 30 minutes, offert",
      "Feuille de route concrète sur 12-24 mois",
      "Charte interne d'utilisation de l'IA (RGPD, EU AI Act)",
      "Formation et accompagnement de vos équipes",
      "Quick wins identifiés dès la première semaine",
    ],
  },
  {
    id: "dev",
    icon: "🏗️",
    title: "Sites web & plateformes métier",
    accent: "violet",
    lead: "Des outils web livrés vite, qui marchent, qui durent.",
    benefits: [
      "Sites vitrine, e-commerce, plateformes SaaS",
      "ERP et CRM sur mesure, taillés pour votre métier",
      "Performance élevée et SEO optimisé en standard",
      "Maintenance et évolutions assurées dans la durée",
      "Hébergement en edge mondial inclus",
    ],
  },
];

const accent: Record<string, string> = {
  violet: "#7c3aed",
  red: "#dc2626",
  fuchsia: "#c026d3",
};
const accentBg: Record<string, string> = {
  violet: "rgba(124,58,237,0.06)",
  red: "rgba(220,38,38,0.05)",
  fuchsia: "rgba(192,38,211,0.06)",
};
const accentBorder: Record<string, string> = {
  violet: "rgba(124,58,237,0.30)",
  red: "rgba(220,38,38,0.30)",
  fuchsia: "rgba(192,38,211,0.28)",
};
---

<Layout
  title="Services LOGIQ IA · Agents IA, automatisation, conseil, web"
  description="Quatre piliers pour transformer votre entreprise avec l'IA : agents IA sur mesure, automatisation des workflows, conseil stratégique, plateformes web métier. Audit gratuit."
  canonical="https://logiq-ia.fr/services/"
>
  <Header />

  <main class="bg-white">
    <section class="relative overflow-hidden pt-32 sm:pt-40">
      <div
        aria-hidden
        class="pointer-events-none absolute inset-x-0 top-0 -z-10 h-96 opacity-25"
        style="background: radial-gradient(ellipse at 30% 50%, #a78bfa 0%, transparent 60%), radial-gradient(ellipse at 70% 50%, #f87171 0%, transparent 60%); filter: blur(80px);"
      >
      </div>

      <div class="mx-auto max-w-5xl px-6 pb-16">
        <div
          class="inline-flex items-center gap-2 rounded-full border px-3 py-1 text-xs font-medium uppercase tracking-[0.2em]"
          style="border-color: rgba(124,58,237,0.30); background: rgba(124,58,237,0.06); color: #6d28d9;"
        >
          Services
        </div>
        <h1 class="mt-6 text-balance text-5xl font-bold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl" style="color: #0a0a0a;">
          Tout ce qu'il faut<br />
          pour <span class="text-gradient">passer à l'action</span>.
        </h1>
        <p class="mt-6 max-w-2xl text-lg" style="color: #404040;">
          Pas de promesses creuses, pas de slides sans suite. Nous livrons des
          solutions IA et des plateformes qui tournent en production dès la
          première semaine.
        </p>
      </div>
    </section>

    <section class="mx-auto max-w-5xl space-y-16 px-6 py-16 sm:space-y-24 sm:py-24">
      {services.map((s) => (
        <article id={s.id} class="grid gap-8 md:grid-cols-[200px_1fr]">
          <div>
            <div
              class="inline-flex h-16 w-16 items-center justify-center rounded-2xl text-3xl"
              style={`background: ${accentBg[s.accent]}; border: 1px solid ${accentBorder[s.accent]};`}
            >
              {s.icon}
            </div>
          </div>
          <div>
            <h2 class="text-3xl font-bold tracking-tight sm:text-4xl" style="color: #0a0a0a;">
              {s.title}
            </h2>
            <p class="mt-3 text-lg" style="color: #404040;">
              {s.lead}
            </p>
            <ul class="mt-6 space-y-2.5" style="color: #404040;">
              {s.benefits.map((b) => (
                <li class="flex gap-3">
                  <svg
                    viewBox="0 0 16 16"
                    fill="currentColor"
                    class="mt-1 h-4 w-4 shrink-0"
                    style={`color: ${accent[s.accent]};`}
                    aria-hidden
                  >
                    <path d="M13.854 3.146a.5.5 0 010 .708l-7 7a.5.5 0 01-.708 0l-3-3a.5.5 0 11.708-.708L6.5 9.793l6.646-6.647a.5.5 0 01.708 0z"/>
                  </svg>
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </section>

    <section class="relative overflow-hidden bg-neutral-50 py-24 sm:py-32">
      <div class="mx-auto max-w-3xl px-6 text-center">
        <h2 class="text-4xl font-bold tracking-tight sm:text-5xl" style="color: #0a0a0a;">
          Audit gratuit en <span class="text-gradient">30 minutes</span>.
        </h2>
        <p class="mx-auto mt-6 max-w-xl text-lg" style="color: #404040;">
          On échange sur votre métier, vos points de friction, vos ambitions.
          Vous repartez avec un diagnostic clair et un plan d'action concret.
          Sans engagement.
        </p>
        <a
          href="/contact"
          class="mt-10 inline-flex items-center gap-2 rounded-full px-8 py-3.5 text-base font-semibold text-white transition-all hover:-translate-y-0.5"
          style="background: linear-gradient(90deg, #7c3aed 0%, #c026d3 50%, #dc2626 100%); box-shadow: 0 12px 30px -10px rgba(220,38,38,0.45);"
        >
          Réserver un créneau
          <svg viewBox="0 0 16 16" fill="currentColor" class="h-4 w-4" aria-hidden>
            <path d="M6 3l5 5-5 5V3z" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
